<Window x:Class="DeepSeekBrowser.Views.ApiKeyManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek API Key"
        Height="620" Width="820"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DsWindow}">
  <DockPanel Margin="{StaticResource DsDialogMargin}" LastChildFill="True">
    <Border DockPanel.Dock="Bottom" Style="{StaticResource DsDialogFooter}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="关闭" Click="Close_Click" Style="{StaticResource DsPrimaryButton}" MinWidth="88"/>
      </StackPanel>
    </Border>

    <ScrollViewer Style="{StaticResource DsScrollViewer}" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="API Key" Style="{StaticResource DsPageTitle}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
          <Ellipse Width="8" Height="8" Fill="{StaticResource DsSuccess}" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBlock x:Name="ServerStatusText" Style="{StaticResource DsPageSubtitle}" Margin="0"/>
        </StackPanel>

        <Border Style="{StaticResource DsCard}" Margin="{StaticResource DsSectionGap}">
          <StackPanel>
            <TextBlock Text="API Key 认证" Style="{StaticResource DsSectionTitle}"/>
            <TextBlock Text="启用后，所有外部请求需要携带 API Key（本机 Agent 走 127.0.0.1 免认证）"
                       Style="{StaticResource DsHint}" Margin="0,4,0,12"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="启用认证" Style="{StaticResource DsBody}"/>
                <TextBlock x:Name="AuthStatusText" Style="{StaticResource DsHint}" Margin="0,4,0,0"/>
              </StackPanel>
              <CheckBox x:Name="EnableAuthCheck" Grid.Column="1" VerticalAlignment="Center"
                        Style="{StaticResource DsCheckBox}" Content=""
                        Checked="EnableAuth_Changed" Unchecked="EnableAuth_Changed"/>
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource DsCard}" Margin="{StaticResource DsSectionGap}">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="API Key 列表" Style="{StaticResource DsSectionTitle}"/>
                <TextBlock x:Name="KeyStatsText" Style="{StaticResource DsHint}" Margin="0,4,0,0"/>
              </StackPanel>
              <Button Grid.Column="1" Content="+ 新建 API Key" Click="CreateKey_Click"
                      Style="{StaticResource DsPrimaryButton}" Padding="14,8"/>
            </Grid>

            <Border x:Name="EmptyPanel" DockPanel.Dock="Top" Padding="32" Background="#FAFAFA"
                    CornerRadius="10" BorderBrush="{StaticResource DsBorder}" BorderThickness="1">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🔑" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="暂无 API Key" Style="{StaticResource DsBody}" HorizontalAlignment="Center"/>
                <TextBlock Text="点击上方按钮创建新的 API Key" Style="{StaticResource DsHint}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
              </StackPanel>
            </Border>

            <DataGrid x:Name="KeysGrid" Style="{StaticResource DsDataGrid}"
                      AutoGenerateColumns="False" CanUserDeleteRows="False"
                      MinHeight="120" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
                <DataGridTemplateColumn Header="API Key" Width="*">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding MaskedKey}" FontFamily="Consolas" VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource DsText}"/>
                        <Button Content="复制" Tag="{Binding Key}" Click="CopyKey_Click"
                                Style="{StaticResource DsGhostButton}" Padding="8,2" Margin="8,0,0,0"
                                FontSize="11"/>
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="启用" Width="56">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Checked="KeyEnabled_Changed" Unchecked="KeyEnabled_Changed"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="调用次数" Binding="{Binding UsageCount}" Width="72"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAtText}" Width="130"/>
                <DataGridTemplateColumn Header="操作" Width="64">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Content="删除" Tag="{Binding Id}" Click="DeleteKey_Click"
                              Style="{StaticResource DsDangerLinkButton}" HorizontalAlignment="Left"/>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
