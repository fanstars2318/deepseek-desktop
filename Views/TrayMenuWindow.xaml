<Window x:Class="DeepSeekBrowser.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FontFamily="{StaticResource DsFont}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowActivated="True">
  <Border Background="{StaticResource DsCardBg}"
          BorderBrush="{StaticResource DsBorder}"
          BorderThickness="1"
          CornerRadius="12"
          Padding="6"
          SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
    </Border.Effect>
    <StackPanel MinWidth="188">
      <TextBlock Text="DeepSeek"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource DsCaptionBrush}"
                 Margin="12,8,12,6"/>
      <Button Content="显示主窗口"
              Click="ShowMainWindow_Click"
              Style="{StaticResource DsTrayMenuItem}"/>
      <Border Height="1" Background="{StaticResource DsBorder}" Margin="8,4"/>
      <Button Content="退出 DeepSeek"
              Click="Exit_Click"
              Style="{StaticResource DsTrayMenuItemDanger}"/>
    </StackPanel>
  </Border>
</Window>
