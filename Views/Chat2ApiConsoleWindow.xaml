<Window x:Class="DeepSeekBrowser.Views.Chat2ApiConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="DeepSeek API"
        Width="1180" Height="760"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DsWindow}">
  <Grid>
    <Grid x:Name="WebViewHost" Opacity="0">
      <wv2:WebView2 x:Name="ConsoleWebView"/>
    </Grid>
    <Border x:Name="LoadingOverlay" Background="#f9fafb" Panel.ZIndex="10">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <ProgressBar IsIndeterminate="True" Width="160" Height="4" Margin="0,0,0,16"
                     Foreground="#4d6bfe" Background="#e5e7eb" BorderThickness="0"/>
        <TextBlock Text="加载中…" FontSize="14" Foreground="#374151" HorizontalAlignment="Center"/>
        <TextBlock Text="DeepSeek API 管理" FontSize="12" Foreground="#9ca3af" Margin="0,8,0,0"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
