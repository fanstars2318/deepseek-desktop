<Window x:Class="DeepSeekBrowser.Views.DsMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek"
        MinWidth="400"
        MaxWidth="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        Style="{StaticResource DsWindow}">
  <Border Margin="24" Style="{StaticResource DsCard}" Padding="24,22">
    <StackPanel>
      <TextBlock x:Name="TitleText" Style="{StaticResource DsPageTitle}"/>
      <TextBlock x:Name="MessageText" Style="{StaticResource DsBody}" TextWrapping="Wrap"
                 Margin="0,10,0,0" LineHeight="22"/>
      <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
        <Button x:Name="CancelButton" Content="取消" MinWidth="80" MinHeight="36"
                Click="CancelButton_Click" Style="{StaticResource DsGhostButton}" Margin="0,0,10,0"/>
        <Button x:Name="OkButton" Content="确定" MinWidth="80" MinHeight="36"
                Click="OkButton_Click" Style="{StaticResource DsPrimaryButton}" IsDefault="True"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
