<Window x:Class="DeepSeekBrowser.Views.ClosePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek"
        MinWidth="440"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource DsWindow}">
  <Border Margin="24" Style="{StaticResource DsCard}" Padding="24,22">
    <StackPanel MinWidth="380">
      <TextBlock Text="关闭 DeepSeek" Style="{StaticResource DsPageTitle}"/>
      <TextBlock Style="{StaticResource DsHint}" Margin="0,0,0,22"
                 Text="本地 API 管理与 MCP 可在后台继续运行，请选择："/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="MinimizeBtn" Content="最小化到托盘" MinWidth="120"
                Click="MinimizeBtn_Click" Style="{StaticResource DsAccentGhostButton}" Margin="0,0,10,0"/>
        <Button x:Name="ExitBtn" Content="退出" MinWidth="80"
                Click="ExitBtn_Click" Style="{StaticResource DsGhostButton}" Margin="0,0,10,0"/>
        <Button x:Name="CancelBtn" Content="取消" MinWidth="72"
                Click="CancelBtn_Click" Style="{StaticResource DsGhostButton}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
