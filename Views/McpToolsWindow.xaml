<Window x:Class="DeepSeekBrowser.Views.McpToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek · MCP 工具"
        Height="440" Width="400"
        MinHeight="320" MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Style="{StaticResource DsWindow}">
  <Grid Margin="{StaticResource DsDialogMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,14">
      <TextBlock x:Name="TitleText" Style="{StaticResource DsPageTitle}"/>
      <TextBlock Style="{StaticResource DsHint}" Margin="0,0,0,0" Text="Agent 可调用的 MCP 工具"/>
    </StackPanel>

    <ListBox x:Name="ToolsList" Grid.Row="1" Style="{StaticResource DsListBox}" Margin="0,0,0,4"/>

    <Border Grid.Row="2" Style="{StaticResource DsDialogFooter}" Margin="0">
      <Button Content="关闭" Click="Close_Click" Style="{StaticResource DsPrimaryButton}"
              HorizontalAlignment="Right" MinWidth="80"/>
    </Border>
  </Grid>
</Window>
