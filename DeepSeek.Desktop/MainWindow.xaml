<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DeepSeek.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="using:Microsoft.UI.Xaml.Controls"
    Title="DeepSeek">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="8" Spacing="8">
            <Button Content="对话" Click="ChatNavButton_Click" />
            <Button Content="Agent" Click="AgentNavButton_Click" />
            <Button Content="设置" Click="SettingsNavButton_Click" />
        </StackPanel>

        <Grid x:Name="ShellGrid" Grid.Row="1">
            <Grid x:Name="ChatHost" />
            <ProgressRing
                x:Name="LoadingRing"
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="True" />
            <Frame x:Name="ContentFrame" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
