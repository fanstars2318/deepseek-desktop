{
  "id": "code-review",
  "version": 1,
  "checkpoint": "after_each_node",
  "nodes": [
    { "id": "explore", "type": "subagent", "role": "explore", "prompt": "Read-only survey for code review." },
    { "id": "implement", "type": "subagent", "role": "implementer", "prompt": "Apply minimal fixes from explore findings." },
    { "id": "verify", "type": "tool", "tool": "bash", "args": { "command": "dotnet test" } },
    { "id": "human", "type": "interrupt", "prompt": "Approve merge?" }
  ],
  "edges": [
    { "from": "explore", "to": "implement" },
    { "from": "implement", "to": "verify" },
    { "from": "verify", "to": "human", "condition": "last_exit_code != 0" },
    { "from": "verify", "to": "human" }
  ]
}
