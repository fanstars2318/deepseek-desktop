<Window x:Class="DeepSeekBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="DeepSeek"
        Height="800"
        Width="1280"
        MinHeight="600"
        MinWidth="900"
        Background="{StaticResource DsBg}"
        Style="{StaticResource DsWindow}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
  <Grid x:Name="WebSurfaceGrid">
    <Grid.CacheMode>
      <BitmapCache RenderAtScale="1" SnapsToDevicePixels="True"/>
    </Grid.CacheMode>
    <wv2:WebView2 x:Name="WebView" />
    <wv2:WebView2 x:Name="AgentWebView" Visibility="Collapsed"/>
    <wv2:WebView2 x:Name="BridgeWebView" Width="1" Height="1" Visibility="Collapsed" IsHitTestVisible="False"/>
    <Border x:Name="LoadingOverlay" Background="{StaticResource DsBg}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="320">
        <Image Width="64" Height="64" Margin="0,0,0,24"
               Source="pack://application:,,,/Assets/logo.png"
               Stretch="Uniform"/>
        <TextBlock Text="正在启动 DeepSeek"
                   FontFamily="{StaticResource DsFont}"
                   FontSize="17" FontWeight="SemiBold"
                   Foreground="{StaticResource DsTitle}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="加载网页会话与 API 管理…"
                   Style="{StaticResource DsHint}"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
